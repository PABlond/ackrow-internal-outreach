OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Optional. Leave empty to use local SQLite at data/outreach.sqlite.
DATABASE_URL=file:/absolute/path/to/outreach-app/data/outreach.sqlite
DATABASE_AUTH_TOKEN=

# If DATABASE_URL is a remote Turso/libSQL URL, the app uses an embedded local
# replica by default for speed and syncs it with Turso.
# Set DATABASE_USE_REMOTE_DIRECT=1 to force every query to hit Turso directly.
DATABASE_REPLICA_PATH=
DATABASE_SYNC_INTERVAL_MS=5000
DATABASE_USE_REMOTE_DIRECT=0
