  "devDependencies": {
    "@react-router/dev": "^7.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
